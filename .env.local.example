# 默认可以不写，项目会走 demo 模式
AGENT_MODEL_MODE=demo

# 真实模型接入留到后续阶段；当前运行入口只完整支持 demo 模式。
# 后续接入时会继续使用这些配置名。
# AGENT_MODEL_MODE=dev
# AGENT_MODEL_ID=openai:gpt-4.1
# OPENAI_API_KEY=your-openai-key
# AGENT_MODEL_BASE_URL=https://api.openai.com/v1
#
# AGENT_MODEL_ID=anthropic:claude-sonnet-4-5
# ANTHROPIC_API_KEY=your-anthropic-key
# AGENT_MODEL_BASE_URL=https://api.anthropic.com/v1
